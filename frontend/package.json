{
  "name": "cocoa-frontend",
  "version": "1.0.0",
  "description": "Cocoa avatar marketplace -- web frontend for main/api_server.py",
  "private": true,
  "type": "module",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
