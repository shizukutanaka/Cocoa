# Cocoa Environment Variables
# Copy this file to .env and configure with your actual values.
#
# This file lists ONLY variables actually read by the live app (main/api_server.py
# and main/main.py plus everything they import). Cocoa has ~95 modules under
# main/, but roughly 60 of them are not imported by either entry point (dead
# R&D code — blockchain/NFT/VR integrations, alternate config layers, etc.);
# any env var those modules read (STRIPE_API_KEY, DATABASE_URL, SECRET_KEY,
# ENVIRONMENT, LOG_LEVEL, ...) currently has no effect and is deliberately
# omitted here so this file doesn't document settings that do nothing.

# ============================================================================
# CRITICAL SECURITY SETTINGS — set these before any real deployment
# ============================================================================

# JWT signing key for auth_manager.py (access/refresh tokens). If unset, a
# random per-process key is generated: tokens are invalidated on every
# restart and won't validate across multiple workers/replicas. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
COCOA_JWT_SECRET=

# 2FA (TOTP) encryption key for two_factor_auth.py. Required to use 2FA at
# all — setup_2fa()/enable_2fa() raise if this is unset (fails closed, no
# insecure default). Generate the same way as COCOA_JWT_SECRET.
COCOA_2FA_SECRET=

# Legacy bearer-token auth for a small number of endpoints in api_server.py.
# Fails closed when unset (that legacy path is simply disabled) — only set
# this if something in your deployment still depends on it.
API_SECRET_TOKEN=

# HMAC key redis_cache_manager.py uses to sign pickled (non-JSON-serializable)
# cache values before storing them, and to verify on read. Required if you
# run with Redis caching enabled and cache non-JSON-serializable objects;
# without it, signed-pickle values are rejected rather than trusted blindly.
COCOA_CACHE_HMAC_KEY=

# ============================================================================
# CORS
# ============================================================================

# Comma-separated list of allowed origins for the frontend. Defaults to the
# Vite/CRA dev-server ports (http://localhost:3000, http://localhost:5173)
# when unset, so local development needs no configuration. Set this to your
# real frontend origin(s) in production.
COCOA_CORS_ORIGINS=

# ============================================================================
# ADMIN BOOTSTRAP
# ============================================================================

# auth_manager.py creates a default admin account on first run unless this is
# set to "false". Leave COCOA_ADMIN_PASSWORD unset to have a random password
# generated and logged once (recommended); set it to choose the password
# yourself instead.
COCOA_CREATE_DEFAULT_ADMIN=true
COCOA_ADMIN_PASSWORD=

# ============================================================================
# AUTH TUNING (all optional — sane defaults shown)
# ============================================================================

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
RESET_TOKEN_EXPIRE_MINUTES=15
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
MAX_BOOKMARKS=1000
MAX_FOLLOWING=2000

# Only relevant in a non-production debugging session: exposes the raw
# password-reset token in the API response instead of only emailing/logging
# it. Never set this to true in production.
COCOA_EXPOSE_RESET_TOKEN=false

# ============================================================================
# RATE LIMITING (main/rate_limiter.py — all optional, requests/minute)
# ============================================================================

RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_PURCHASE_PER_MINUTE=30

# ============================================================================
# MARKETPLACE LIMITS (main/avatar_marketplace.py — optional)
# ============================================================================

MAX_PRICE_CREDITS=10000000
MAX_GRANT_CREDITS=100000000

# ============================================================================
# POSTGRESQL (main/database_manager.py — optional)
# ============================================================================
# Most business data (marketplace, cart, 2FA, etc.) is still in-memory only
# (see FEATURE_AUDIT.md 3-4); only a couple of api_server.py code paths use
# this database connection today. Safe to leave at defaults for local dev.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=cocoa_db
DB_USER=cocoa_user
DB_PASSWORD=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false

# ============================================================================
# REDIS (main/redis_cache_manager.py — optional)
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================================
# i18n / TRANSLATION PROVIDERS (main/i18n_manager.py — all optional)
# ============================================================================
# Only needed if you use the machine-translation fallback for untranslated
# UI strings. Leave blank to disable that fallback entirely.

GOOGLE_TRANSLATE_API_KEY=
MICROSOFT_TRANSLATOR_KEY=
DEEPL_API_KEY=
