# Otedama Production Environment Variables
# Copy this file to .env and configure with your actual values

# ============================================================================
# CRITICAL SECURITY SETTINGS - MUST BE CHANGED IN PRODUCTION
# ============================================================================

# Application Environment (development, production, testing)
OTEDAMA_ENVIRONMENT=production

# Secret key for session encryption (CHANGE THIS - 32+ characters)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
OTEDAMA_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_32_CHARS_OR_MORE

# Encryption key for data at rest (CHANGE THIS - 32+ characters)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
OTEDAMA_ENCRYPTION_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_32_CHARS_OR_MORE

# Admin credentials
OTEDAMA_ADMIN_USER=admin
# Generate hashed password:
# python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"
OTEDAMA_ADMIN_PASS=$2b$12$EXAMPLE_HASH_REPLACE_WITH_ACTUAL_HASH

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database type (sqlite, postgresql, mysql)
OTEDAMA_DATABASE_TYPE=sqlite

# SQLite configuration (default)
# OTEDAMA_DB_PATH=data/otedama.db

# PostgreSQL configuration (uncomment if using PostgreSQL)
# OTEDAMA_DB_HOST=localhost
# OTEDAMA_DB_PORT=5432
# OTEDAMA_DB_NAME=otedama
# OTEDAMA_DB_USER=otedama_user
# OTEDAMA_DB_PASSWORD=secure_database_password

# MySQL configuration (uncomment if using MySQL)
# OTEDAMA_DB_HOST=localhost
# OTEDAMA_DB_PORT=3306
# OTEDAMA_DB_NAME=otedama
# OTEDAMA_DB_USER=otedama_user
# OTEDAMA_DB_PASSWORD=secure_database_password

# ============================================================================
# WEB SERVER CONFIGURATION
# ============================================================================

# Web admin interface
OTEDAMA_WEB_HOST=127.0.0.1
OTEDAMA_WEB_PORT=8080

# Force HTTPS (recommended for production)
OTEDAMA_FORCE_HTTPS=true

# Allowed host headers (comma-separated)
OTEDAMA_ALLOWED_HOSTS=localhost,127.0.0.1

# Session configuration
OTEDAMA_SESSION_COOKIE_NAME=otedama_session
OTEDAMA_SESSION_SAMESITE=Strict
OTEDAMA_SESSION_SECURE=true
OTEDAMA_SESSION_IDLE_TIMEOUT_SECONDS=900
OTEDAMA_SESSION_DURATION_MINUTES=60
OTEDAMA_SESSION_ROTATION_MINUTES=30

# Trust proxy count (if behind reverse proxy)
OTEDAMA_TRUST_PROXY_COUNT=0

# ============================================================================
# SECURITY POLICY
# ============================================================================

# IP binding (bind session to client IP)
OTEDAMA_STRICT_IP_BINDING=true

# User-Agent binding (bind session to User-Agent)
OTEDAMA_STRICT_UA_BINDING=true

# Rate limiting
OTEDAMA_FALLBACK_RATE_LIMIT=180
OTEDAMA_FALLBACK_RATE_WINDOW=60

# Max content length (bytes)

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
COCOA_LOG_ENCRYPTION_KEY=your_32_byte_encryption_key_here_for_production_use_only
COCOA_LOG_DIR=logs
COCOA_LOG_LEVEL=INFO

# Audit log configuration
OTEDAMA_AUDIT_MAX_BYTES=5242880
OTEDAMA_MAX_LOG_PREVIEW_LINES=200

OTEDAMA_PERFORMANCE_INTERVAL=10
OTEDAMA_PERFORMANCE_CPU_THRESHOLD=80
OTEDAMA_PERFORMANCE_MEMORY_THRESHOLD=85

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================

# Backup directory
OTEDAMA_BACKUP_PATH=backups/

# Backup encryption key (separate from main encryption key)
OTEDAMA_BACKUP_ENCRYPTION_KEY=CHANGE_THIS_TO_ANOTHER_SECURE_RANDOM_STRING

# Backup retention (days)

# ============================================================================
# NOTIFICATION SETTINGS (Optional)
# ============================================================================

# Email# Notification settings
# OTEDAMA_SMTP_SERVER=smtp.example.com
# OTEDAMA_SMTP_PORT=587
# OTEDAMA_SMTP_USER=otedama@example.com
# OTEDAMA_SMTP_PASSWORD=smtp_password
# OTEDAMA_SMTP_FROM=otedama@example.com
# OTEDAMA_SMTP_TO=admin@example.com,ops@example.com

# Webhook notifications
# OTEDAMA_WEBHOOK_URL=https://hooks.example.com/otedama
# OTEDAMA_WEBHOOK_SECRET=webhook_signing_secret

# ============================================================================
# BILLING (Stripe)
# ============================================================================

# Stripe secret API key (sk_live_... or sk_test_...)
STRIPE_API_KEY=

# Stripe webhook endpoint secret used to verify webhook signatures
STRIPE_WEBHOOK_SECRET=

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Development mode (disable in production)
OTEDAMA_DEVELOPMENT_MODE=false
{{ ... }}
# Debug mode (disable in production)
OTEDAMA_DEBUG=false

# Enable 2FA
OTEDAMA_ENABLE_2FA=true

# Enable audit logging
OTEDAMA_ENABLE_AUDIT_LOG=true

# ============================================================================
# ADVANCED SETTINGS (Usually don't need to change)
# ============================================================================

# Config preview limits
OTEDAMA_MAX_CONFIG_PREVIEW_CHARS=20000

# Network policy cache
OTEDAMA_NETWORK_POLICY_CACHE_SECONDS=60

# Language
OTEDAMA_LOCALE=ja

# Timezone
TZ=Asia/Tokyo
