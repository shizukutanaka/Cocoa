{
    "enabled": true,
    "settings": {
        "log_level": "info",
        "max_bytes": 10485760,
        "backup_count": 10,
        "compression_interval": 1800,
        "log_format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
        "date_format": "%Y-%m-%d %H:%M:%S",
        "log_file": "otedama.log",
        "log_dir": "logs",
        "avatar_log_level": "info",
        "preset_log_level": "info"
    }
}
